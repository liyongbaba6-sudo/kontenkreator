// Fungsi bantuan untuk membuat scene cadangan jika API utama sedang sibuk atau mengalami limitasi
const generateFallbackScenes = (topic, audience, style, sceneCount, niche) => {
  const scenes = [];
  const stylesInfo = {
    'Sinematik': 'Pencahayaan dramatis, warna kontras tinggi, depth of field dangkal, transisi lambat yang anggun.',
    'Vlog Kasual': 'Kamera dipegang tangan (handheld), bergerak aktif, pencahayaan natural, gaya interaktif langsung ke lensa.',
    'Animasi 2D': 'Gaya flat design modern, warna-warna cerah pastel, transisi kartun yang dinamis dan mulus.',
    'Animasi 3D': 'Visual 3D realistis atau gaya kartun Pixar/Disney, pencahayaan volumetrik, tekstur detail.',
    'Minimalis': 'Ruang kosong bersih (negative space), palet warna netral/monokrom, transisi slide sederhana.',
    'Energik': 'Transisi potong cepat (quick cuts), warna neon berani, pergerakan kamera cepat (crash zoom/whip pan).',
    'Retro': 'Filter VHS atau film analog, warna pudar (faded), grain kasar, transisi light leak.',
    'Moody': 'Pencahayaan low-key, bayangan pekat, tone warna dingin atau kebiruan, suasana misterius.',
    'Cyberpunk': 'Cahaya neon kontras (pink/biru), suasana kota malam, efek glitch, futuristik.',
    'Dokumenter': 'Pencahayaan natural, komposisi rule of thirds, pergerakan kamera stabil dan observasional.'
  };

  const styleDesc = stylesInfo[style] || stylesInfo['Sinematik'];
  const nicheContext = niche && niche !== 'Umum' ? ` untuk audiens pecinta ${niche}` : '';

  for (let i = 1; i <= sceneCount; i++) {
    let role = "Isi Konten Utama";
    let text = `Fakta menarik tentang ${topic}`;
    let dialogText = `Nah, bagian penting dari ${topic} yang wajib banget kalian catat adalah poin yang satu ini...`;
    
    if (i === 1) {
      role = "Hook (Penarik Perhatian)";
      text = `Hai ${audience}! Tahukah kamu rahasia ${topic}?`;
      dialogText = `Hai para ${audience}! Pernah nggak sih kalian kepikiran rahasia tersembunyi di balik ${topic}? Yuk kita bahas!`;
    } else if (i === sceneCount) {
      role = "Call to Action (Penutup)";
      text = `Follow & bagikan video ini untuk info ${topic} lainnya!`;
      dialogText = `Kira-kira tips apa lagi ya yang seru? Tulis di kolom komentar, jangan lupa follow dan share video ini ke teman kalian!`;
    }

    scenes.push({
      sceneNumber: i,
      title: role,
      visualPrompt: `Visual detail berfokus pada elemen ${topic}${nicheContext}. ${styleDesc}`,
      cameraMovement: i % 2 === 0 ? "Pan perlahan dari kiri ke kanan (Slow Pan)" : "Zoom in secara halus untuk mengunci fokus penonton (Slow Zoom)",
      textOverlay: text,
      dialog: dialogText,
      audioSfx: "Musik latar bertempo sedang yang estetik, ditambah efek transisi suara 'Swoosh' halus."
    });
  }

  return {
    title: `Panduan Video Kreatif: ${topic}`,
    scenes: scenes
  };
};

export default function App() {
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [loginId, setLoginId] = useState('');
  const [loginPassword, setLoginPassword] = useState('');
  const [loginError, setLoginError] = useState('');

  const handleLogin = (e) => {
    e.preventDefault();
    if (loginId === 'babayong' && loginPassword === 'babayong123') {
      setIsLoggedIn(true);
      setLoginError('');
    } else {
      setLoginError('ID atau Kata Sandi salah! Akses ditolak.');
    }
  };

  const handleLogout = () => {
    setIsLoggedIn(false);
    setLoginId('');
    setLoginPassword('');
    setResult(null); 
  };

  const [topic, setTopic] = useState('');
  const [audience, setAudience] = useState('');
  const [style, setStyle] = useState('Sinematik');
  const [niche, setNiche] = useState('Umum'); 
  const [mediaFiles, setMediaFiles] = useState([]); 
  const [fileError, setFileError] = useState('');
  const [sceneCount, setSceneCount] = useState(3);
  
  const [isGenerating, setIsGenerating] = useState(false);
  const [result, setResult] = useState(null);
  const [error, setError] = useState('');
  
  // State untuk melacak status tersalin dari masing-masing tombol
  const [copiedIndex, setCopiedIndex] = useState(null);
  const [copiedAll, setCopiedAll] = useState(false);
  const [copiedField, setCopiedField] = useState(null);

  const apiKey = ""; // API key is injected by the environment

  // Fungsi salin
  const executeCopy = (text, onSuccess) => {
    if (navigator.clipboard && navigator.clipboard.writeText) {
      navigator.clipboard.writeText(text)
        .then(() => {
          onSuccess();
        })
        .catch((err) => {
          console.warn("Clipboard API gagal, mencoba metode alternatif...", err);
          runFallbackCopy(text, onSuccess);
        });
    } else {
      runFallbackCopy(text, onSuccess);
    }
  };

  const runFallbackCopy = (text, onSuccess) => {
    try {
      const textArea = document.createElement("textarea");
      textArea.value = text;
      
      textArea.style.position = 'fixed';
      textArea.style.top = '-9999px';
      textArea.style.left = '-9999px';
      textArea.style.width = '2em';
      textArea.style.height = '2em';
      textArea.style.padding = '0';
      textArea.style.border = 'none';
      textArea.style.outline = 'none';
      textArea.style.boxShadow = 'none';
      textArea.style.background = 'transparent';
      
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();
      
      const successful = document.execCommand('copy');
      if (successful) {
        onSuccess();
      } else {
        console.error("Gagal menyalin menggunakan perintah execCommand.");
      }
      document.body.removeChild(textArea);
    } catch (err) {
      console.error("Semua metode salin gagal diterapkan:", err);
    }
  };

  const handleFileUpload = (e) => {
    const files = Array.from(e.target.files);
    const maxSize = 10 * 1024 * 1024; // Maksimal 10MB per file

    let errorMsg = '';
    const validFiles = [];

    files.forEach(file => {
      if (file.size > maxSize) {
        errorMsg = `File "${file.name}" terlalu besar (Maks 10MB).`;
      } else {
        validFiles.push(file);
      }
    });

    if (errorMsg) setFileError(errorMsg);
    else setFileError('');

    validFiles.forEach(file => {
      const reader = new FileReader();
      reader.onloadend = () => {
        const result = reader.result;
        const base64Data = result.split(',')[1];
        setMediaFiles(prev => [...prev, {
          name: file.name,
          type: file.type,
          preview: result,
          base64Data: base64Data,
          isImage: file.type.startsWith('image/')
        }]);
      };
      reader.readAsDataURL(file);
    });
    
    // Reset input agar bisa memilih file yang sama lagi jika dihapus
    e.target.value = null;
  };

  const removeMedia = (index) => {
    setMediaFiles(prev => prev.filter((_, i) => i !== index));
  };

  const generateWithAI = async () => {
    setIsGenerating(true);
    setError('');
    setResult(null);

    const promptText = `
      Anda adalah asisten sutradara dan pembuat prompt untuk editor video profesional. 
      Tugas Anda adalah membuat panduan editing/prompt video pendek dengan:
      Topik: "${topic}"
      Kategori/Niche Kreator: "${niche}"
      Target Audiens: "${audience || 'Umum'}"
      Gaya Visual: "${style}"
      ${mediaFiles.length > 0 ? `PERHATIAN: Pengguna juga telah melampirkan gambar/video. Analisis media yang dilampirkan ini dan gunakan sebagai referensi utama untuk objek, warna, pencahayaan, atau suasana di dalam visual prompt setiap scene.` : ''}
      Jumlah Scene: ${sceneCount}
      
      ATURAN MUTLAK: SETIAP scene HARUS dan HANYA berdurasi tepat 10 detik.
      
      Pastikan naskah/dialog, pilihan kata, dan referensi visual SANGAT RELEVAN dengan Kategori/Niche Kreator "${niche}". 
      Misalnya, jika nichenya 'Otomotif', gunakan istilah otomotif; jika 'Kuliner', fokus pada deskripsi rasa dan tampilan makanan.
      
      Berikan output HANYA dalam format JSON valid dengan struktur persis seperti ini:
      {
        "title": "Judul Ide Video",
        "scenes": [
          {
            "sceneNumber": 1,
            "title": "Peran Scene (misal: Hook, Penjelasan, CTA)",
            "visualPrompt": "Deskripsi visual yang sangat detail (warna, objek, suasana)",
            "cameraMovement": "Instruksi pergerakan kamera (misal: Tracking shot, Fast zoom)",
            "textOverlay": "Teks spesifik singkat yang muncul di layar",
            "dialog": "Naskah narasi atau dialog lengkap yang diucapkan oleh talent/voiceover (sesuaikan gaya bahasa dengan audiens target secara persuasif)",
            "audioSfx": "Musik latar dan efek suara spesifik"
          }
        ]
      }
    `;

    // Siapkan array parts untuk menampung teks dan media
    const promptParts = [{ text: promptText }];
    
    // Masukkan data media ke dalam format yang diterima Gemini
    mediaFiles.forEach(file => {
      promptParts.push({
        inlineData: {
          mimeType: file.type,
          data: file.base64Data
        }
      });
    });

    const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-preview-09-2025:generateContent?key=${apiKey}`;
    const payload = {
      contents: [{ parts: promptParts }],
      generationConfig: {
        responseMimeType: "application/json"
      }
    };

    const delays = [1000, 2000, 4000, 8000, 16000];
    let success = false;

    for (let i = 0; i < 5; i++) {
      try {
        const response = await fetch(url, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });

        if (!response.ok) throw new Error('Network error');

        const data = await response.json();
        const jsonText = data.candidates?.[0]?.content?.parts?.[0]?.text;
        
        if (jsonText) {
          setResult(JSON.parse(jsonText));
          success = true;
          break;
        }
      } catch (err) {
        if (i < 4) {
          await new Promise(r => setTimeout(r, delays[i]));
        }
      }
    }

    if (!success) {
      console.log("AI API gagal, beralih ke generator lokal otomatis.");
      setResult(generateFallbackScenes(topic, audience || 'Umum', style, sceneCount, niche));
    }
    
    setIsGenerating(false);
  };

  const handleGenerate = (e) => {
    e.preventDefault();
    if (!topic.trim()) {
      setError('Mohon masukkan topik utama video terlebih dahulu.');
      return;
    }
    generateWithAI();
  };

  const copyAllPrompts = () => {
    if (!result) return;
    let fullText = `JUDUL VIDEO: ${result.title}\n`;
    fullText += `Kategori/Niche: ${niche} | Gaya Visual: ${style} | Target: ${audience || 'Umum'}\n`;
    fullText += `Total Durasi: ${result.scenes.length * 10} detik\n\n`;

    result.scenes.forEach(scene => {
      const startTime = (scene.sceneNumber - 1) * 10;
      const endTime = scene.sceneNumber * 10;
      const timeFormat = `0:${startTime.toString().padStart(2, '0')} - 0:${endTime.toString().padStart(2, '0')}`;
      
      fullText += `================ SCENE ${scene.sceneNumber} (${timeFormat}) ================\n`;
      fullText += `Peran/Fungsi: ${scene.title}\n`;
      fullText += `• Visual Prompt : ${scene.visualPrompt}\n`;
      fullText += `• Kamera/Movement : ${scene.cameraMovement}\n`;
      if (scene.dialog) {
        fullText += `• Dialog/Voiceover : "${scene.dialog}"\n`;
      }
      fullText += `• Teks Overlay : "${scene.textOverlay}"\n`;
      fullText += `• Audio & SFX : ${scene.audioSfx}\n\n`;
    });

    executeCopy(fullText, () => {
      setCopiedAll(true);
      setTimeout(() => setCopiedAll(false), 2000);
    });
  };

  const copySinglePrompt = (scene, index) => {
    const startTime = (scene.sceneNumber - 1) * 10;
    const endTime = scene.sceneNumber * 10;
    const timeFormat = `0:${startTime.toString().padStart(2, '0')} - 0:${endTime.toString().padStart(2, '0')}`;

    let text = `SCENE ${scene.sceneNumber} (${timeFormat}) - ${scene.title}\n`;
    text += `Visual: ${scene.visualPrompt}\n`;
    text += `Kamera: ${scene.cameraMovement}\n`;
    if (scene.dialog) {
      text += `Dialog/VO: "${scene.dialog}"\n`;
    }
    text += `Teks Overlay: "${scene.textOverlay}"\n`;
    text += `Audio: ${scene.audioSfx}`;

    executeCopy(text, () => {
      setCopiedIndex(index);
      setTimeout(() => setCopiedIndex(null), 2000);
    });
  };

  const copyField = (text, fieldId) => {
    executeCopy(text, () => {
      setCopiedField(fieldId);
      setTimeout(() => setCopiedField(null), 2000);
    });
  };

  if (!isLoggedIn) {
    return (
      <div className="min-h-screen bg-slate-900 flex flex-col items-center justify-center p-4 selection:bg-blue-500 selection:text-white font-sans relative overflow-hidden">
        <div className="absolute top-[-10%] left-[-10%] w-96 h-96 bg-blue-600/20 rounded-full blur-3xl pointer-events-none"></div>
        <div className="absolute bottom-[-10%] right-[-10%] w-96 h-96 bg-indigo-600/20 rounded-full blur-3xl pointer-events-none"></div>
        
        <div className="max-w-md w-full bg-slate-800/80 backdrop-blur-xl p-8 rounded-3xl border border-slate-700 shadow-2xl z-10">
          <div className="text-center mb-8">
            <div className="inline-flex items-center justify-center p-4 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-2xl mb-4 shadow-lg shadow-blue-500/30">
              <Crown className="w-12 h-12 text-white" />
            </div>
            <h1 className="text-3xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400 mb-2">
              DAFA AI KONTEN KREATOR
            </h1>
            <p className="text-slate-400 text-sm">
              Silakan login untuk mengakses tools pembuat naskah & prompt video otomatis.
            </p>
          </div>

          <form onSubmit={handleLogin} className="space-y-5">
            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300 flex items-center gap-2">
                <User className="w-4 h-4 text-blue-400" />
                ID Pengguna
              </label>
              <input
                type="text"
                value={loginId}
                onChange={(e) => setLoginId(e.target.value)}
                placeholder="Masukkan ID"
                className="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-100 placeholder:text-slate-600"
              />
            </div>

            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300 flex items-center gap-2">
                <Lock className="w-4 h-4 text-indigo-400" />
                Kata Sandi
              </label>
              <input
                type="password"
                value={loginPassword}
                onChange={(e) => setLoginPassword(e.target.value)}
                placeholder="••••••••"
                className="w-full bg-slate-900/50 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-100 placeholder:text-slate-600"
              />
            </div>

            {loginError && (
              <div className="flex items-center gap-2 text-red-400 bg-red-400/10 p-3 rounded-xl border border-red-400/20 text-sm animate-pulse">
                <AlertCircle className="w-4 h-4 flex-shrink-0" />
                <p>{loginError}</p>
              </div>
            )}

            <button
              type="submit"
              className="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold py-3.5 rounded-xl shadow-lg shadow-blue-500/25 transition-all active:scale-[0.98] mt-2"
            >
              Masuk ke Aplikasi
            </button>
          </form>
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-slate-900 text-slate-200 p-4 md:p-8 font-sans selection:bg-blue-500 selection:text-white">
      {/* Header Navigasi DAFA AI */}
      <div className="max-w-5xl mx-auto flex justify-between items-center mb-8 bg-slate-800 border border-slate-700 p-4 rounded-2xl shadow-md">
        <div className="flex items-center gap-3">
          <div className="p-2 bg-blue-500/20 rounded-lg">
            <Crown className="w-6 h-6 text-blue-400" />
          </div>
          <span className="font-bold text-transparent bg-clip-text bg-gradient-to-r from-blue-400 to-indigo-400 tracking-wide hidden sm:inline-block">
            DAFA AI KONTEN KREATOR
          </span>
        </div>
        <div className="flex items-center gap-4">
          <div className="text-sm text-slate-400 hidden sm:block">
            Halo, <span className="text-indigo-400 font-semibold">{loginId}</span>
          </div>
          <button 
            onClick={handleLogout}
            className="flex items-center gap-2 text-sm bg-slate-700 hover:bg-red-500/20 text-slate-300 hover:text-red-400 px-4 py-2 rounded-xl transition-all border border-slate-600 hover:border-red-500/30"
          >
            <LogOut className="w-4 h-4" />
            <span>Keluar</span>
          </button>
        </div>
      </div>

      <div className="max-w-5xl mx-auto space-y-8">
        
        {/* Header Section */}
        <div className="text-center space-y-4">
          <div className="inline-flex items-center justify-center p-3 bg-blue-500/10 rounded-2xl mb-2">
            <Video className="w-10 h-10 text-blue-400 animate-pulse" />
          </div>
          <h1 className="text-3xl md:text-5xl font-extrabold tracking-tight">
            <span className="bg-gradient-to-r from-blue-400 to-indigo-400 bg-clip-text text-transparent">
              Editor Prompt
            </span> Generator
          </h1>
          <p className="text-slate-400 max-w-xl mx-auto text-sm md:text-base">
            Otomatisasi pembuatan naskah, dialog, dan instruksi editing video dengan presisi durasi 
            <strong className="text-indigo-400 font-semibold"> 10 detik per scene</strong>. Sempurna untuk TikTok, Reels, dan Shorts.
          </p>
        </div>

        {/* Input Form */}
        <div className="bg-slate-800 rounded-2xl border border-slate-700 p-6 md:p-8 shadow-xl">
          <form onSubmit={handleGenerate} className="grid grid-cols-1 md:grid-cols-2 gap-6">
            
            <div className="space-y-2 md:col-span-2">
              <label className="text-sm font-medium text-slate-300 flex items-center gap-2">
                <FileText className="w-4 h-4 text-blue-400" />
                Topik Utama Video
              </label>
              <input
                type="text"
                value={topic}
                onChange={(e) => setTopic(e.target.value)}
                placeholder="Misal: 3 Trik Psikologi Jualan Laris Manis"
                className="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-100 placeholder:text-slate-600"
              />
            </div>

            <div className="space-y-2 md:col-span-2">
              <label className="text-sm font-medium text-slate-300 flex items-center gap-2">
                <MonitorPlay className="w-4 h-4 text-purple-400" />
                Kategori / Niche Kreator
              </label>
              <select
                value={niche}
                onChange={(e) => setNiche(e.target.value)}
                className="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-purple-500 transition-all text-slate-100 appearance-none cursor-pointer"
              >
                <option value="Umum">Umum / Lainnya</option>
                <option value="Edukasi & Tutorial">Edukasi & Tutorial (Tips, Trik, Pengetahuan)</option>
                <option value="Bisnis & Keuangan">Bisnis & Keuangan (Marketing, Saham, Crypto)</option>
                <option value="Teknologi & Gadget">Teknologi & Gadget (Review, Unboxing, IT)</option>
