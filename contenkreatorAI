                <option value="Kuliner & Memasak">Kuliner & Memasak (Resep, Review Makanan)</option>
                <option value="Kesehatan & Kebugaran">Kesehatan & Kebugaran (Olahraga, Diet, Mental Health)</option>
                <option value="Hiburan & Komedi">Hiburan & Komedi (Sketsa, Prank, Storytelling)</option>
                <option value="Gaming & Esports">Gaming & Esports (Gameplay, Review Game, Livestream Highlight)</option>
                <option value="Traveling & Lifestyle">Traveling & Lifestyle (Vlog Liburan, Aesthetic Life)</option>
                <option value="Otomotif">Otomotif (Review Mobil/Motor, Tips Perawatan)</option>
                <option value="Seni & Desain">Seni & Desain (Menggambar, DIY, Crafting)</option>
                <option value="Motivasi & Pengembangan Diri">Motivasi & Pengembangan Diri (Inspirasi, Mindset)</option>
              </select>
            </div>

            {/* Unggah Media */}
            <div className="space-y-3 md:col-span-2 bg-slate-900/50 p-4 rounded-xl border border-slate-700/50">
              <label className="text-sm font-medium text-slate-300 flex items-center gap-2">
                <Upload className="w-4 h-4 text-sky-400" />
                Unggah File Referensi (Gambar/Video Maks 10MB) - Opsional
              </label>
              
              <div className="flex items-center gap-4">
                <label className="cursor-pointer bg-slate-800 hover:bg-slate-700 border border-slate-600 text-slate-200 px-4 py-2.5 rounded-lg transition-all flex items-center gap-2 text-sm font-medium">
                  <Upload className="w-4 h-4" />
                  Pilih File
                  <input 
                    type="file" 
                    className="hidden" 
                    accept="image/*,video/mp4,video/webm" 
                    multiple 
                    onChange={handleFileUpload}
                  />
                </label>
                <span className="text-xs text-slate-500">
                  Didukung: JPG, PNG, WEBP, MP4
                </span>
              </div>

              {fileError && (
                <p className="text-red-400 text-xs mt-1">{fileError}</p>
              )}

              {/* Gallery Preview Media */}
              {mediaFiles.length > 0 && (
                <div className="flex flex-wrap gap-3 mt-4 pt-3 border-t border-slate-700/50">
                  {mediaFiles.map((file, idx) => (
                    <div key={idx} className="relative group w-24 h-24 rounded-lg overflow-hidden border border-slate-600 bg-slate-800 flex items-center justify-center">
                      {file.isImage ? (
                        <img src={file.preview} alt="preview" className="w-full h-full object-cover" />
                      ) : (
                        <div className="flex flex-col items-center gap-1">
                          <Film className="w-8 h-8 text-slate-400" />
                          <span className="text-[10px] text-slate-400 truncate w-20 text-center px-1">Video</span>
                        </div>
                      )}
                      
                      <button 
                        type="button"
                        onClick={() => removeMedia(idx)}
                        className="absolute top-1 right-1 bg-red-500/80 hover:bg-red-500 text-white p-1 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"
                        title="Hapus media"
                      >
                        <X className="w-3 h-3" />
                      </button>
                    </div>
                  ))}
                </div>
              )}
            </div>

            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">Target Audiens</label>
              <input
                type="text"
                value={audience}
                onChange={(e) => setAudience(e.target.value)}
                placeholder="Misal: Kreator Pemula / Anak Muda"
                className="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-100 placeholder:text-slate-600"
              />
            </div>

            <div className="space-y-2">
              <label className="text-sm font-medium text-slate-300">Gaya Visual</label>
              <select
                value={style}
                onChange={(e) => setStyle(e.target.value)}
                className="w-full bg-slate-900 border border-slate-700 rounded-xl px-4 py-3 focus:outline-none focus:ring-2 focus:ring-blue-500 transition-all text-slate-100 appearance-none cursor-pointer"
              >
                <option value="Sinematik">Sinematik (Dramatis, High Quality, Bokeh)</option>
                <option value="Vlog Kasual">Vlog Kasual (Handheld, Natural, Otentik)</option>
                <option value="Animasi 2D">Animasi 2D & Motion Graphics (Flat, Colorful)</option>
                <option value="Animasi 3D">Animasi 3D (Realistis / Gaya Pixar)</option>
                <option value="Minimalis">Minimalis & Estetik (Bersih, Soft Tone)</option>
                <option value="Energik">Energik (Cepat, Dinamis, Hyper-editing)</option>
                <option value="Retro">Retro / Vintage (VHS, Sepia, Nostalgia 90an)</option>
                <option value="Moody">Dark & Moody (Low Key, Misterius, Kontras)</option>
                <option value="Cyberpunk">Cyberpunk / Neon (Futuristik, Cahaya Neon, Glow)</option>
                <option value="Dokumenter">Dokumenter (Realistis, Stabil, Observasional)</option>
              </select>
            </div>

            <div className="space-y-2 md:col-span-2">
              <label className="text-sm font-medium text-slate-300 flex items-center gap-2">
                <Clock className="w-4 h-4 text-indigo-400" />
                Jumlah Scene (Masing-masing scene = 10 Detik)
              </label>
              <div className="flex items-center gap-4">
                <input
                  type="range"
                  min="1"
                  max="10"
                  value={sceneCount}
                  onChange={(e) => setSceneCount(parseInt(e.target.value))}
                  className="w-full h-2 bg-slate-700 rounded-lg appearance-none cursor-pointer accent-blue-500"
                />
                <span className="bg-slate-900 border border-slate-700 px-4 py-2 rounded-xl font-bold text-indigo-400 min-w-[120px] text-center">
                  {sceneCount} Scene
                  <span className="block text-xs font-normal text-slate-500">{sceneCount * 10} Detik Total</span>
                </span>
              </div>
            </div>

            {error && (
              <div className="md:col-span-2 flex items-center gap-2 text-red-400 bg-red-400/10 p-3 rounded-xl border border-red-400/20 animate-bounce">
                <AlertCircle className="w-5 h-5" />
                <p className="text-sm">{error}</p>
              </div>
            )}

            <div className="md:col-span-2 pt-2">
              <button
                type="submit"
                disabled={isGenerating}
                className="w-full bg-gradient-to-r from-blue-600 to-indigo-600 hover:from-blue-500 hover:to-indigo-500 text-white font-bold py-4 rounded-xl shadow-lg shadow-blue-500/25 transition-all flex items-center justify-center gap-2 disabled:opacity-70 disabled:cursor-not-allowed"
              >
                {isGenerating ? (
                  <>
                    <Loader2 className="w-5 h-5 animate-spin" />
                    Sedang Meracik Prompt AI...
                  </>
                ) : (
                  <>
                    <Sparkles className="w-5 h-5" />
                    Generate Editor Prompt
                  </>
                )}
              </button>
            </div>
          </form>
        </div>

        {/* Results Section */}
        {result && (
          <div className="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
            
            {/* Header Result */}
            <div className="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 bg-indigo-500/10 border border-indigo-500/20 p-5 rounded-2xl">
              <div>
                <h2 className="text-xl font-bold text-white">{result.title}</h2>
                <div className="flex flex-wrap gap-2 mt-1">
                  <span className="text-xs bg-purple-500/20 text-purple-300 px-2 py-1 rounded border border-purple-500/30">
                    Niche: {niche}
                  </span>
                  <span className="text-xs text-indigo-300 px-2 py-1">
                    Total Durasi: {result.scenes.length * 10} detik ({result.scenes.length} Scene)
                  </span>
                </div>
              </div>
              <button
                onClick={copyAllPrompts}
                className="flex items-center gap-2 bg-indigo-600 hover:bg-indigo-500 active:scale-95 border border-indigo-400/30 px-5 py-2.5 rounded-xl text-sm font-semibold text-white transition-all w-full sm:w-auto justify-center shadow-lg shadow-indigo-600/15"
              >
                {copiedAll ? (
                  <>
                    <CheckCheck className="w-4 h-4 text-green-300" />
                    <span>Semua Tersalin!</span>
                  </>
                ) : (
                  <>
                    <Copy className="w-4 h-4" />
                    <span>Salin Semua Scene</span>
                  </>
                )}
              </button>
            </div>

            {/* Scenes List */}
            <div className="space-y-6">
              {result.scenes.map((scene, idx) => {
                const startSeconds = (scene.sceneNumber - 1) * 10;
                const endSeconds = scene.sceneNumber * 10;
                const timeStr = `0:${String(startSeconds).padStart(2, '0')} - 0:${String(endSeconds).padStart(2, '0')}`;

                return (
                  <div key={idx} className="bg-slate-800 rounded-2xl border border-slate-700 overflow-hidden shadow-lg transition-all hover:border-slate-600 relative group">
                    
                    {/* Scene Card Header */}
                    <div className="bg-slate-800/80 border-b border-slate-700 px-5 py-4 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-3">
                      <div className="flex flex-wrap items-center gap-3">
                        <span className="bg-blue-600 text-white text-xs font-bold px-3 py-1.5 rounded-md">
                          Scene {scene.sceneNumber}
                        </span>
                        <span className="flex items-center gap-1.5 text-slate-300 text-sm font-mono bg-slate-900 px-2.5 py-1 rounded">
                          <Clock className="w-3.5 h-3.5 text-indigo-400" />
                          {timeStr}
                        </span>
                        <span className="font-semibold text-slate-200 ml-1">
                          {scene.title}
                        </span>
                      </div>
                      
                      <button
                        onClick={() => copySinglePrompt(scene, idx)}
                        className="p-2.5 bg-slate-900 hover:bg-slate-700 active:scale-95 text-slate-300 hover:text-white rounded-xl border border-slate-700 transition-all flex items-center gap-2 text-xs font-medium w-full sm:w-auto justify-center"
                        title="Salin Seluruh Detail Scene Ini"
                      >
                        {copiedIndex === idx ? (
                          <>
                            <CheckCheck className="w-4 h-4 text-green-400 animate-scale-up" />
                            <span className="text-green-400">Scene {scene.sceneNumber} Tersalin!</span>
                          </>
                        ) : (
                          <>
                            <Copy className="w-4 h-4" />
                            <span>Salin Satu Scene Ini</span>
                          </>
                        )}
                      </button>
                    </div>

                    {/* Scene Body / Prompts */}
                    <div className="p-5 grid grid-cols-1 md:grid-cols-2 gap-4">
                      
                      {/* Kolom Kiri: Visual & Kamera */}
                      <div className="space-y-4">
                        
                        {/* Prompt Visual */}
                        <div className="bg-slate-900/40 p-4 rounded-xl border border-slate-800 hover:border-slate-700 transition-colors relative group/field">
                          <div className="flex justify-between items-start mb-2">
                            <h4 className="text-xs font-bold text-blue-400 uppercase tracking-wider flex items-center gap-1.5">
                              <Video className="w-3.5 h-3.5" /> Prompt Visual
                            </h4>
                            <button 
                              onClick={() => copyField(scene.visualPrompt, `${idx}-visual`)}
                              className="text-slate-500 hover:text-white active:scale-90 transition-all p-1 hover:bg-slate-800 rounded"
                              title="Salin Visual Saja"
                            >
                              {copiedField === `${idx}-visual` ? (
                                <CheckCheck className="w-4 h-4 text-green-400" />
                              ) : (
                                <Copy className="w-4 h-4" />
                              )}
                            </button>
                          </div>
                          <p className="text-sm text-slate-300 leading-relaxed pr-2">{scene.visualPrompt}</p>
                        </div>
                        
                        {/* Pergerakan Kamera */}
                        <div className="bg-slate-900/40 p-4 rounded-xl border border-slate-800 hover:border-slate-700 transition-colors relative group/field">
                          <div className="flex justify-between items-start mb-2">
                            <h4 className="text-xs font-bold text-indigo-400 uppercase tracking-wider flex items-center gap-1.5">
                              <Camera className="w-3.5 h-3.5" /> Pergerakan Kamera
                            </h4>
                            <button 
                              onClick={() => copyField(scene.cameraMovement, `${idx}-camera`)}
                              className="text-slate-500 hover:text-white active:scale-90 transition-all p-1 hover:bg-slate-800 rounded"
                              title="Salin Kamera Saja"
                            >
                              {copiedField === `${idx}-camera` ? (
                                <CheckCheck className="w-4 h-4 text-green-400" />
                              ) : (
                                <Copy className="w-4 h-4" />
                              )}
                            </button>
                          </div>
                          <p className="text-sm text-slate-300 leading-relaxed pr-2">{scene.cameraMovement}</p>
                        </div>

                      </div>

                      {/* Kolom Ranan: Dialog, Teks & Audio */}
                      <div className="space-y-4">
                        
                        {/* Dialog / Voiceover */}
                        {(scene.dialog || scene.narration) && (
                          <div className="bg-orange-950/15 p-4 rounded-xl border border-orange-900/30 hover:border-orange-800/40 transition-colors relative group/field">
                            <div className="flex justify-between items-start mb-2">
                              <h4 className="text-xs font-bold text-orange-400 uppercase tracking-wider flex items-center gap-1.5">
                                <MessageSquare className="w-3.5 h-3.5" /> Dialog / Voiceover (Naskah)
                              </h4>
                              <button 
                                onClick={() => copyField(scene.dialog || scene.narration, `${idx}-dialog`)}
                                className="text-slate-500 hover:text-orange-300 active:scale-90 transition-all p-1 hover:bg-orange-900/20 rounded"
                                title="Salin Naskah Dialog Saja"
                              >
                                {copiedField === `${idx}-dialog` ? (
                                  <CheckCheck className="w-4 h-4 text-green-400" />
                                ) : (
                                  <Copy className="w-4 h-4" />
                                )}
                              </button>
                            </div>
                            <p className="text-sm text-orange-100/90 leading-relaxed italic font-serif">
                              "{scene.dialog || scene.narration}"
                            </p>
                          </div>
                        )}

                        {/* Teks Layar (Overlay) */}
                        <div className="bg-slate-900/40 p-4 rounded-xl border border-slate-800 hover:border-slate-700 transition-colors relative group/field">
                          <div className="flex justify-between items-start mb-2">
                            <h4 className="text-xs font-bold text-green-400 uppercase tracking-wider flex items-center gap-1.5">
                              <Type className="w-3.5 h-3.5" /> Teks Layar (Overlay)
                            </h4>
                            <button 
                              onClick={() => copyField(scene.textOverlay, `${idx}-text`)}
                              className="text-slate-500 hover:text-white active:scale-90 transition-all p-1 hover:bg-slate-800 rounded"
                              title="Salin Teks Saja"
                            >
                              {copiedField === `${idx}-text` ? (
                                <CheckCheck className="w-4 h-4 text-green-400" />
                              ) : (
                                <Copy className="w-4 h-4" />
                              )}
                            </button>
                          </div>
                          <p className="text-sm text-slate-200 font-semibold leading-relaxed">
                            "{scene.textOverlay}"
                          </p>
                        </div>

                        {/* Audio & SFX */}
                        <div className="bg-slate-900/40 p-4 rounded-xl border border-slate-800 hover:border-slate-700 transition-colors relative group/field">
                          <div className="flex justify-between items-start mb-2">
                            <h4 className="text-xs font-bold text-purple-400 uppercase tracking-wider flex items-center gap-1.5">
                              <Volume2 className="w-3.5 h-3.5" /> Audio & SFX
                            </h4>
                            <button 
                              onClick={() => copyField(scene.audioSfx, `${idx}-audio`)}
                              className="text-slate-500 hover:text-white active:scale-90 transition-all p-1 hover:bg-slate-800 rounded"
                              title="Salin Audio Saja"
                            >
                              {copiedField === `${idx}-audio` ? (
                                <CheckCheck className="w-4 h-4 text-green-400" />
                              ) : (
                                <Copy className="w-4 h-4" />
                              )}
                            </button>
                          </div>
                          <p className="text-sm text-slate-300 leading-relaxed pr-2">
                            {scene.audioSfx}
                          </p>
                        </div>

                      </div>

                    </div>
                  </div>
                );
              })}
            </div>

          </div>
        )}

      </div>
    </div>
  );
}
